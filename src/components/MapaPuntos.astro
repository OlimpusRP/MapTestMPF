---
interface Props {
	fullHeight?: boolean;
	variant?: 'standard' | 'modified';
}

const { fullHeight = false, variant = 'modified' } = Astro.props;
---

<div class={`map-wrapper ${fullHeight ? 'is-full' : ''}`} data-variant={variant}>
	<div id="map" aria-label="Mapa de puntos de interés" role="region"></div>
</div>

<script>
	import L from 'leaflet';
	import 'leaflet/dist/leaflet.css';
	import { MAPA_NOMBRES } from '../data/mapaNombres';

	type PuntoInteres = {
		id?: number | string;
		nombre?: string;
		lat?: number | string;
		lon?: number | string;
		icono?: string | null;
	};

	const mapElement = document.getElementById('map');
	const wrapperElement = document.querySelector('.map-wrapper');
	const variant = wrapperElement?.getAttribute('data-variant') === 'standard' ? 'standard' : 'modified';

	async function initMap() {
		if (!mapElement) {
			return;
		}

		const map = L.map('map').setView([-34.6037, -58.3816], 12);

		const tileUrl =
			variant === 'standard'
				? 'https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png'
				: 'https://{s}.basemaps.cartocdn.com/rastertiles/voyager_nolabels/{z}/{x}/{y}{r}.png';

		L.tileLayer(tileUrl, {
			subdomains: 'abcd',
			maxZoom: 20,
			attribution: '&copy; OpenStreetMap contributors &copy; CARTO',
		}).addTo(map);

		L.control.scale({ imperial: false }).addTo(map);

		try {
			const response = await fetch('https://mpfciudad.gob.ar/api/v1.0/puntos_interes');
			if (!response.ok) {
				throw new Error(`Error HTTP ${response.status}`);
			}

			const puntos = (await response.json()) as PuntoInteres[];
			const bounds: L.LatLngTuple[] = [];

			for (const punto of puntos) {
				const lat = Number(punto.lat);
				const lon = Number(punto.lon);

				if (Number.isNaN(lat) || Number.isNaN(lon)) {
					continue;
				}

				const icono = typeof punto.icono === 'string' && punto.icono.length > 0 ? punto.icono : 'pin-uod';
				const markerIcon = L.icon({
					iconUrl: `https://mpfciudad.gob.ar/img/site/mapa/${icono}.svg`,
					iconSize: [28, 34],
					iconAnchor: [14, 34],
					popupAnchor: [0, -30],
				});

				const marker = L.marker([lat, lon], { icon: markerIcon }).addTo(map);
				const puntoId = Number(punto.id);
				const customName = Number.isNaN(puntoId) ? undefined : MAPA_NOMBRES[puntoId];
				const popupText =
					typeof customName === 'string' && customName.length > 0
						? customName
						: typeof punto.nombre === 'string' && punto.nombre.length > 0
							? punto.nombre
							: '';

				if (popupText.length > 0) {
					marker.bindPopup(popupText);
				}

				bounds.push([lat, lon]);
			}

			if (bounds.length > 0) {
				map.fitBounds(bounds, { padding: [20, 20] });
			}
		} catch (error) {
			console.error(error);
		}
	}

	initMap();
</script>

<style>
	#map {
		height: 70vh;
		min-height: 420px;
		width: 100%;
		margin-top: 0;
	}

	.map-wrapper.is-full #map {
		height: calc(100vh - 2rem);
		min-height: 700px;
	}
</style>