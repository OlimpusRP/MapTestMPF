---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Mapa de puntos de interés</h1>
			<p>Visualización en tiempo real desde la API del MPF Ciudad.</p>
			<div id="status">Cargando puntos...</div>
			<div id="map" aria-label="Mapa de puntos de interés" role="region"></div>
		</main>
		<Footer />
		<script>
			import L from 'leaflet';
			import 'leaflet/dist/leaflet.css';

			type ApiPoint = Record<string, unknown> & {
				coordenadas?: unknown;
				geometry?: unknown;
				properties?: unknown;
			};

			function isObject(value: unknown): value is Record<string, unknown> {
				return typeof value === 'object' && value !== null;
			}

			const statusElement = document.getElementById('status');
			const mapElement = document.getElementById('map');

			const colorPalette = ['#e11d48', '#2563eb', '#16a34a', '#f59e0b', '#7c3aed', '#0f766e'];

			function hashString(value: string): number {
				let hash = 0;
				for (let index = 0; index < value.length; index += 1) {
					hash = (hash << 5) - hash + value.charCodeAt(index);
					hash |= 0;
				}
				return Math.abs(hash);
			}

			function pickColor(point: ApiPoint): string {
				const fromApi = [point?.color, point?.colour, point?.hex, point?.color_hex].find(
					(value) => typeof value === 'string' && value.length > 0,
				);

				if (typeof fromApi === 'string') {
					return fromApi;
				}

				const category = [point?.tipo, point?.categoria, point?.category].find(
					(value) => typeof value === 'string' && value.length > 0,
				);

				if (typeof category !== 'string') {
					return '#2563eb';
				}

				return colorPalette[hashString(category) % colorPalette.length];
			}

			function parseCoordinatePair(raw: unknown): { lat: number; lng: number } | null {
				if (!Array.isArray(raw) || raw.length < 2) {
					return null;
				}

				const [first, second] = raw as [unknown, unknown];
				const firstNumber = Number(first);
				const secondNumber = Number(second);

				if (Number.isNaN(firstNumber) || Number.isNaN(secondNumber)) {
					return null;
				}

				if (Math.abs(firstNumber) <= 90 && Math.abs(secondNumber) <= 180) {
					return { lat: firstNumber, lng: secondNumber };
				}

				if (Math.abs(secondNumber) <= 90 && Math.abs(firstNumber) <= 180) {
					return { lat: secondNumber, lng: firstNumber };
				}

				return null;
			}

			function normalizePoint(raw: unknown): ApiPoint {
				if (!isObject(raw)) {
					return {};
				}

				if (isObject(raw.properties)) {
					return { ...raw.properties, ...raw };
				}

				return raw;
			}

			function extractPoints(payload: unknown): ApiPoint[] {
				if (Array.isArray(payload)) {
					return payload.map(normalizePoint);
				}

				if (!isObject(payload)) {
					return [];
				}

				const containers = [payload.data, payload.features, payload.resultados, payload.items];

				for (const container of containers) {
					if (Array.isArray(container)) {
						return container.map(normalizePoint);
					}
				}

				return [];
			}

			function extractCoordinates(point: ApiPoint): { lat: number; lng: number } | null {
				const latCandidates = ['lat', 'latitude', 'y'];
				const lngCandidates = ['lng', 'lon', 'long', 'longitude', 'x'];

				const getCoordinate = (keys: string[]): number | null => {
					for (const key of keys) {
						if (point?.[key] !== undefined && point?.[key] !== null) {
							const parsed = Number(point[key]);
							if (!Number.isNaN(parsed)) return parsed;
						}
					}
					return null;
				};

				const lat = getCoordinate(latCandidates);
				const lng = getCoordinate(lngCandidates);

				if (lat !== null && lng !== null) return { lat, lng };

				const coordinateCandidates = [
					point?.coordenadas,
					isObject(point?.geometry) ? (point.geometry as Record<string, unknown>).coordinates : null,
					isObject(point?.ubicacion) ? (point.ubicacion as Record<string, unknown>).coordinates : null,
					isObject(point?.location) ? (point.location as Record<string, unknown>).coordinates : null,
				];

				for (const candidate of coordinateCandidates) {
					const parsed = parseCoordinatePair(candidate);
					if (parsed) return parsed;
				}

				const textCoordinate = [point?.wkt, point?.geom, point?.geometry_text].find(
					(value) => typeof value === 'string' && value.toUpperCase().startsWith('POINT('),
				);

				if (typeof textCoordinate === 'string') {
					const matches = textCoordinate.match(/POINT\s*\(([-\d\.]+)\s+([-\d\.]+)\)/i);
					if (matches) {
						const lngFromText = Number(matches[1]);
						const latFromText = Number(matches[2]);
						if (!Number.isNaN(latFromText) && !Number.isNaN(lngFromText)) {
							return { lat: latFromText, lng: lngFromText };
						}
					}
				}

				return null;
			}

			function extractName(point: ApiPoint, index: number): string {
				const fields = [point?.nombre, point?.name, point?.titulo, point?.title];
				const firstText = fields.find((value) => typeof value === 'string' && value.length > 0);
				return typeof firstText === 'string' ? firstText : `Punto ${index + 1}`;
			}

			async function initMap() {
				if (!mapElement || !statusElement) {
					return;
				}

				const map = L.map('map').setView([-34.6037, -58.3816], 12);

				L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
					maxZoom: 19,
					attribution: '&copy; OpenStreetMap contributors',
				}).addTo(map);

				try {
					const response = await fetch('https://mpfciudad.gob.ar/api/v1.0/puntos_interes');
					if (!response.ok) {
						throw new Error(`Error HTTP ${response.status}`);
					}

					const payload: unknown = await response.json();
					const points: ApiPoint[] = extractPoints(payload);

					const bounds: L.LatLngTuple[] = [];

					points.forEach((point: ApiPoint, index: number) => {
						const coords = extractCoordinates(point);
						if (!coords) return;

						const marker = L.circleMarker([coords.lat, coords.lng], {
							radius: 7,
							color: '#0f172a',
							weight: 1,
							fillColor: pickColor(point),
							fillOpacity: 0.95,
						}).addTo(map);
						marker.bindPopup(extractName(point, index));
						bounds.push([coords.lat, coords.lng]);
					});

					if (bounds.length > 0) {
						map.fitBounds(bounds, { padding: [30, 30] });
						statusElement.textContent = `Se cargaron ${bounds.length} puntos.`;
					} else {
						statusElement.textContent = 'No se encontraron coordenadas válidas.';
					}
				} catch (error) {
					statusElement.textContent = 'No se pudo cargar la API de puntos de interés.';
					console.error(error);
				}
			}

			initMap();
		</script>
		<style>
			#map {
				height: 70vh;
				min-height: 420px;
				width: 100%;
				border-radius: 12px;
				margin-top: 1rem;
			}

			#status {
				font-size: 1rem;
				margin-top: 0.5rem;
			}
		</style>
	</body>
</html>
