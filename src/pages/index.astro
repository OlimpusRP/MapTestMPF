---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<div class="map-links">
				<a class="bg-[#006272] px-6 rounded-2xl text-white open-map-link" href="/mapa-estandar" target="_blank" rel="noopener noreferrer">
					Mapa estandar
				</a>
				<a class="bg-[#006272] px-6 rounded-2xl text-white open-map-link" href="/mapa-modificado" target="_blank" rel="noopener noreferrer">
					Mapa modificado
				</a>
			</div>
		</main>
		<Footer />
		<style>
			.map-links {
				display: flex;
				gap: 0.75rem;
				margin-bottom: 1rem;
			}

			.open-map-link {
				display: inline-block;
				font-weight: 700;
			}

			.open-map-link,
			.open-map-link:visited,
			.open-map-link:hover,
			.open-map-link:active {
				color: #fff !important;
			}
		</style>
	</body>
</html>
